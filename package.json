{
  "name": "threadbot-runware-backend",
  "version": "1.0.0",
  "description": "Threadbot full-placement product design compiler — clothing app backend running on the Runware.ai platform (native textInference + imageInference + client-side MCP tools).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --enable-source-maps dist/index.js",
    "serve": "node --enable-source-maps dist/server.js",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@runware/sdk-js": "^1.2.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
