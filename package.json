{
  "name": "threadbot-runware-backend",
  "version": "1.0.0",
  "description": "Threadbot full-placement clothing design pipeline running on the Runware.ai platform (LLMs, image models, and media tools).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node --loader tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "selfcheck": "tsx scripts/selfcheck.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "sharp": "^0.35.3",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
