# Twilio Configuration (Required)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+15555551234

# Alert Recipients (Required)
# Comma-separated list of phone numbers in E.164 format
ALERT_RECIPIENTS=+13095550123,+13095550124

# Location Configuration
ZIP=61611
RADIUS_MI=25

# Price Range
MIN_PRICE=70000
MAX_PRICE=230000

# Polling Configuration
POLL_MINUTES=2

# Nominatim Geocoding (Required)
# Provide your contact email as required by Nominatim usage policy
NOMINATIM_EMAIL=your-email@example.com

# Listing Sources (Optional)
# Enable stub provider for testing
ENABLE_STUB=false

# Zillow RSS Feed URL (Optional)
# To get this URL:
# 1. Go to zillow.com
# 2. Search for homes in your desired area with filters
# 3. Look for RSS icon or add ?rss=1 to the search URL
# Example: https://www.zillow.com/homes/61611_rb/?searchQueryState=...&rss=1
ZILLOW_RSS_URL=
