# Runware API key — used for all LLM textInference and image imageInference calls.
# Get one at https://my.runware.ai/keys
RUNWARE_API_KEY=

# Optional: override the default Runware WebSocket/HTTP base if you are on a
# dedicated endpoint. Leave unset to use the platform default.
# RUNWARE_BASE_URL=

# Bearer token forwarded to the Threadbot MCP servers (policy / product
# intelligence / pricing / printful mockups), if those servers require auth.
# Leave unset if the servers are open.
THREADBOT_MCP_BEARER=
