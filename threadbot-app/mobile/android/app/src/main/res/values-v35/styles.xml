<?xml version="1.0" encoding="utf-8"?>
<!-- Android 15 (API 35) forces edge-to-edge. Opt out so the app's existing full-screen layout
     (which already works on API 34 and earlier) renders identically instead of drawing under the
     status/navigation bars. Applies only on API 35+. -->
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
