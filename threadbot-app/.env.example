# --- Fulfillment provider (Printful V1) ---
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=

# --- AI (understand+select + artwork generation) ---
OPENAI_API_KEY=
# Optional: attach your existing hosted MCP servers to the Understand+Select agent.
# Comma-separated "label=url" pairs. Leave empty to run model-only selection.
POLICY_MCP_URL=
PRODUCT_INTELLIGENCE_MCP_URL=

# --- Payments / order trigger ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Hosting ---
# Public base URL for re-hosted preview images (keeps the supplier CDN hidden).
PUBLIC_BASE_URL=http://localhost:3000/public
PORT=3000
